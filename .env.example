# Copy this file to .env and fill in your keys.
# Each provider key is required ONLY if you run that provider's configurations.

# Anthropic — for claude-sonnet-4-6
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI — for gpt-5.5
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google AI Studio — for gemini-3-flash-preview (paid tier required for our quota)
# Get one at https://aistudio.google.com/
GOOGLE_API_KEY=

# Together AI — for DeepSeek-V3.1 and Qwen3.5-397B
# Get one at https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=
